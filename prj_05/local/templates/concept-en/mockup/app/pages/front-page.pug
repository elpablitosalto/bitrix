									text: 'Fashion Look Blue',
									href: '#',
								},
							]
						})



	+e.banner
		.page__container
			+banner({
				image: '2.jpg',
				sources: [
					{
						src: '2.jpg',
						media: '(max-width: 1024px)',
						type: 'image/jpg'
					}
				]
			})



	+e.attention-panel
		.page__container
			+attention-panel({
				control: {
					text: 'Ask a question',
					attr: {
						href: '#askForm',
