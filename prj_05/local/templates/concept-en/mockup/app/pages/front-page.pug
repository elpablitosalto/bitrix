extends /layouts/default/default.pug

block head
	- var pageTitle = 'Main page | Hair Concept Professional';
	- var pageDescription = ' Hair Concept Professional';
	- var pageKeywords = 'hair, concept';

	- var fileName = 'front-page.html';
	- var bodyClass = '';
	- var headerClass = '';
	- var headerWrapperClass = '__header-wrapper';

block content
	+e.banner-carousel
		+banner-carousel({
			items: [
				{
					image: '1.png',
					sources: [
						{
							src: '1-m.png',
							media: '(max-width: 1024px)',
							type: 'image/png'
						}
					]
				},
				{
					image: '1.png',
					sources: [
					{
							src: '1-m.png',
							media: '(max-width: 1024px)',
							type: 'image/png'
						}
					]
				},
				{
					image: '1.png',
					sources: [
						{
							src: '1-m.png',
							media: '(max-width: 1024px)',
							type: 'image/png'
						}
					]
				},
				{
					image: '1.png',
					sources: [
						{
							src: '1-m.png',
							media: '(max-width: 1024px)',
							type: 'image/png'
						}
					]
				}
			]
		})



	+e.info-carousel
		.page__container
			+info-carousel({
				items: [
					{
						illustration: {
							image: '1.jpg'
						},
						title: 'Coloring',
						text: '<p>The cream dye is designed for permanent hair coloring and gentle toning.</p><p>Thanks to its innovative formula, which includes chitosan, the patented U-Sonic Color System complex, and a blend of three oils (olive oil, sweet almond oil, and cedar oil), Profy Touch hair cream dye provides excellent coverage, the most delicate care for hair structure, and a high degree of predictability in coloring results when following the instructions and basic colorist rules.</p>',
						control: {
							text: 'Learn more',
							attr: {
								href: '#'
							}
						}
					},
				]
			})



	+e.section#foot
		+section({
			header: {
				title: {
					tag: 'h1',
					text: 'New Arrivals',
					attr: {
						class: '_size_h2 _font_secondary _align_center _weight_bold'
					}
				}
			}
		})
			+e.content
				.page__container
					+e.entry-carousel
						+entry-carousel({
							items: [
								{
									image: '1.jpg',
									title: 'Сыворотка-питание для секущихся кончиков',
									text: 'Nutri Keratin Serum',
									href: '#',
								},
								{
									image: '2.jpg',
									title: 'Профессиональная стойкая крем-краска для волос',
									text: 'Profy Touch Permanent Color Cream',
									href: '#',
								},
								{
									image: '3.jpg',
									title: 'Маска мега-уход для слабых и поврежденных волос',
									text: 'Mega-Mask',
									href: '#',
								},
								{
									image: '4.jpg',
									title: 'Лосьон для химической завивки',
									text: 'Perm Agent',
									href: '#',
								},
								{
									image: '5.png',
									title: 'Пигменты прямого действия для волос fashion look лимонный',
