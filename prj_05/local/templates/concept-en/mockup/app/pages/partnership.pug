extends /layouts/default/default.pug

block head
	- var pageTitle = 'Partnership | Hair Concept Professional';
	- var pageDescription = ' Hair Concept Professional';
	- var pageKeywords = 'hair, concept';

	- var fileName = 'partnership.html';
	- var bodyClass = '';
	- var headerClass = '';
	- var headerWrapperClass = '__header-wrapper';

block content
	+e.banner-carousel
		+banner-carousel({
			items: [
				{
					image: '4.jpg',
					sources: [
						{
							src: '4-m.jpg',
							media: '(max-width: 1024px)',
							type: 'image/png'
						}
					]
				},
				{
					image: '4.jpg',
					sources: [
					{
							src: '4-m.jpg',
							media: '(max-width: 1024px)',
							type: 'image/png'
						}
					]
				},
				{
					image: '4.jpg',
					sources: [
						{
							src: '4-m.jpg',
							media: '(max-width: 1024px)',
							type: 'image/png'
						}
					]
				},
				{
					image: '4.jpg',
					sources: [
						{
							src: '4-m.jpg',
							media: '(max-width: 1024px)',
							type: 'image/png'
						}
					]
				}
			]
		})

	+e.contacts
		.page__container
			+contacts({
				title: {
					tag: 'h1',
					text: 'Partnership'
				},
				text: 'The meaning is not clear to everyone. The principle of perception is abstract. Judgment clarifies the law of excluded middle. It should be noted that Hegelianism inductively controls transcendental Daoism.',
				note: '<p>According to the previous statement, the attitude toward modernity is viewed through an ambiguous genius. A priori, discreteness is generated by time. Vedanta fills the complex genius while negating the obvious.<p>A priori, the law of excluded middle reflects the deductive method. The law of excluded middle meaningfully fills positivism, tertium non datur. Daoism enables the language of images, tertium non datur. The meaning of life understands itself through conflict, opening new horizons. A priori, the atma jiva controls transcendental positivism, while the letters A, B, I, and O symbolize universally affirmative, universally negative, particularly affirmative, and particularly negative judgments, respectively. Catharsis, of course, mentally creates the world.</p>',
				form: {
					title: 'Partnership application',
					note: 'Fill out the form, and our specialists will respond to you within 48 hours.',
					attr: {
						class: 'js-demo-validated-form'
					},
					fields: [
						{
							type: 'text',
							label: 'Name*',
							name: 'NAME',
							attr: {
								required: true,
								placeholder: 'Your Name'
							}
						},
						{
							type: 'tel',
							label: 'Phone*',
							name: 'PHONE',
							attr: {
								required: true,
								placeholder: '',
								class: 'js-phone-input'
							}
						},
						{
							type: 'email',
							label: 'E-mail*',
							name: 'EMAIL',
							attr: {
								required: true,
								placeholder: 'mail@yahoo.com'
							}
						},
						{
							type: 'textarea',
							label: 'Message*',
							name: 'MESSAGE',
							attr: {
								required: true
							}
						},
					],
					checkbox: {
						text: 'By pressing the button, you agree to the terms of personal data processing.',
						inputAttr: {
							type: 'checkbox',
							name: 'confirm',
							class: 'js-disabling-checkbox'
						},
					},
					controls: [
						{
							text: 'Send',
							attr: {
								type: 'submit',
								class: '_width_full _size_l _text_size-l'
							}
						}
					]
				}
			})