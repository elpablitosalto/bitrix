extends /layouts/default/default.pug

block head
	- var pageTitle = 'Study | Hair Concept Professional';
	- var pageDescription = ' Hair Concept Professional';
	- var pageKeywords = 'hair, concept';

	- var fileName = 'study.html';
	- var bodyClass = '';
	- var headerClass = '';
	- var headerWrapperClass = '__header-wrapper';

block content
	+e.banner-carousel
		+banner-carousel({
			items: [
				{
					image: '1.png',
					sources: [
						{
							src: '1-m.png',
							media: '(max-width: 1024px)',
							type: 'image/png'
						}
					]
				},
				{
					image: '1.png',
					sources: [
						{
							src: '1-m.png',
