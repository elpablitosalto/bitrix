mixin bullet-pagination(item)
	- var DIR = 'assets/blocks/bullet-pagination/';
	- var IMG_DIR = DIR + 'images/';
	// begin .bullet-pagination
	+b.bullet-pagination&attributes(attributes)
		if item
			if item.items
				each button in item.items
					+e.BUTTON.button(type='button')
						!=button.text
		block
	// end .bullet-pagination
