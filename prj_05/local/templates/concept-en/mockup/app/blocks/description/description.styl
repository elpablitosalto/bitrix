DIR = '../blocks/description/'
IMG_DIR = DIR + 'images/'

.description
	display block
	font-size 14px
	font-weight 400
	line-height 1.428



	&__content
		position relative
		overflow hidden
		max-width 900px

		&:after
			content ''
			position absolute
			left 0
			bottom 0
			z-index 1
			display none
			width 100%
			height 100%
			pointer-events none
			background linear-gradient(rgba(255, 255, 255, 0), rgb(255, 255, 255))

			+above(size-m)
				height 76.8924%



	&__controls
		display none
		flex-direction column
		flex-wrap nowrap
		align-items flex-start



	&__control
		flex 0 1 auto
		min-width 171px
		margin 0 0 20px

		&:last-child
			margin-bottom 0



	// Modifiers
	&_state
		&_closed
			.description
				&__content
					display block
					max-height 180px
					margin 0 0 31px

					+above(size-m)
						max-height 251px

					&:last-child
						margin-bottom 0

					&:after
						display block

				&__controls
					display flex