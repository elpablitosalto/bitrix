DIR = '../blocks/info-panel/'
IMG_DIR = DIR + 'images/'

.info-panel
	display block



	&__holder
		+above(size-l)
			display flex
			align-items center
			justify-content space-between
			width 100%



	&__illustration
		width 406px
		margin 0 auto 30px
		box-shadow 0 0 12px 0 rgba($c-black, .12)

		+above(size-l)
			flex-shrink 0
			flex-basis 406px
			margin 0



	&__picture
		width 100%



	&__image
		display block
		width 100%
		height auto



	&__content
		+above(size-l)
			flex-grow 1
			flex-basis auto
			padding 0 0 3px 40px

		+above(size-xl)
			padding 0 0 3px 121px



	&__header
		margin 0 0 35px

		&:last-child
			margin-bottom 0



	&__title
		font-size 20px
		font-weight 400
		line-height 1.4
		text-align center
		text-transform uppercase

		+above(size-l)
			text-align left



	&__text
		font-size 14px
		line-height 1.45



	&__controls
		display flex
		justify-content center
		padding 38px 0 0

		+above(size-l)
			justify-content flex-start



	&__control
		width 100%
		max-width 172px