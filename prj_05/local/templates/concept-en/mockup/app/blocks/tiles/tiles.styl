DIR = '../blocks/tiles/'
IMG_DIR = DIR + 'images/'

.tiles
	display block



	&__list
		display grid
		grid-template-columns repeat(auto-fill, minmax(100%, 1fr))
		grid-gap 30px
		margin 0

		+above(size-m)
			grid-template-columns repeat(auto-fill, minmax(45%, 1fr))
			grid-gap 20px

		+above(size-l)
			grid-template-columns repeat(auto-fill, minmax(30%, 1fr))



	&__item
		display block
		margin 0

		// Modifiers
		&_size
			&_tall
				+above(size-l)
					grid-row-end span 2



	&__panel
		position relative
		display block
		overflow hidden
		height 100%
		color var(--color-white)
		font-size 15px
		font-weight 400
		line-height 1.2
		background var(--color-grey)

		&:before
			+above(size-m)
				content ''
				display block
				width 100%
				height auto
				padding 100% 0 0

		&:after
			content ''
			position absolute
			top 0
			left 0
			z-index 1
			display block
			width 100%
			height 100%
			background linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, .45))

			+above(size-m)
				transform translate(0, 40%)

				def-trn(transform)

		&:hover
			&:after
				+above(size-m)
					transform translate(0, 0)

			.tiles
				&__content
					+above(size-m)
						transform translate(0, 0)



	&__background
		position absolute
		top 0
		left 0
		z-index 0
		display block
		width 100%
		height 100%



	&__image
		display block
		width 100%
		height 100%
		object-fit cover



	&__content
		position relative
		z-index 3
		display block
		padding 20px

		+above(size-m)
			position absolute
			left 0
			bottom 0
			width 100%
			height auto
			padding-right 8px
			transform translate(0, calc(100% - 4.6em))

			def-trn(transform)



	&__title
		display block
		margin 0 0 15px
		font-size 1.6em
		font-weight 700
		line-height 1.21
		text-transform uppercase

		+above(size-m)
			margin 0 0 24px

		&:last-child
			margin-bottom 0



	&__links
		display block
		margin 0
		padding 0



	&__link-item
		margin 0 0 10px
		padding 0

		+above(size-m)
			margin 0

		&:last-child
			margin-bottom 0



	&__link
		display block
		color var(--color-white)
		text-decoration none
		background transparent
		border none

		def-trn(color)

		&:hover
			color var(--color-primary)
			text-decoration none