DIR = '../blocks/video-snippet/'
IMG_DIR = DIR + 'images/'

.video-snippet
	display block
	font-size 14px
	font-weight 400
	line-height 1.44



	&__preview
		position relative
		display block
		overflow hidden
		margin 0 0 4px
		color var(--color-white)
		text-decoration none
		background-color var(--color-dark)

		+above(size-s)
			margin 0 0 8px

		&:hover
			&:before
				opacity .6

			.video-snippet
				&__play-icon
					background-color var(--color-primary)
					border-color var(--color-primary)

		&:last-child
			margin-bottom 0


		&:before
			content ''
			position relative
			z-index 1
			display block
			width 100%
			height auto
			padding 60% 0 0
			background var(--color-darker)
			opacity .3

			def-trn(opacity)

			+above(size-l)
				padding 62.338% 0 0



	&__image
		position absolute
		top 0
		left 0
		z-index 0
		width 100%
		height 100%
		object-fit cover



	&__play-icon
		position absolute
		top 50%
		left 50%
		z-index 2
		display block
		width 60px
		height 60px
		color inherit
		border 2px solid var(--color-white)
		border-radius 50%
		transform translate(-50%, -50%)

		def-trn(background-color, border-color)

		+above(size-s)
			width 80px
			height 80px
			border-width 3px



	&__icon
		position absolute
		top 0
		left 0
		z-index 1
		width 100%
		height 100%
		fill currentColor



	&__title
		margin 0 0 4px
		padding 8px 0 0
		font-family Montserrat, sans-serif
		font-size 14px
		font-weight 500
		line-height 1.214

		+above(size-l)
			font-size 16px
			line-height 1.25

		&:last-child
			margin-bottom 0



	&__text
		margin 0 0 4px
		padding 4px 0 0
		opacity .8

		&:last-child
			margin-bottom 0



	&__links
		display block



	&__link
		position relative
		display inline
		vertical-align middle
		color var(--color-primary)
		text-decoration underline
		background transparent
		border none
		outline none

		def-trn(opacity)

		&:hover
			opacity $hover-opacity