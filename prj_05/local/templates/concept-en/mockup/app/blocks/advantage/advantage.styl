DIR = '../blocks/advantage/'
IMG_DIR = DIR + 'images/'

.advantage
	display block



	&__illustration
		display block
		margin 0 0 22px

		&:last-child
			margin-bottom 0



	&__image
		display block
		width 50px
		height 50px
		object-fit contain
		object-position 0 0



	&__main
		display block



	&__text
		display block
		font-size 12px
		line-height 1.667

		+above(size-l)
			font-size 14px
			line-height 1.4