DIR = '../blocks/detail-card/'
IMG_DIR = DIR + 'images/'

.detail-card
	display block
	padding 19px 0 23px

	+above(size-m)
		display grid
		grid-template-rows auto 1fr auto
		grid-template-columns 1fr 52.5%
		grid-template-areas 'image header' 'image main' 'footer main'
		grid-gap 24px 40px

	+above(size-l)
		grid-gap 24px 78px
		padding 41px 41px 45px




	&__header
		grid-area header
		margin 0 0 30px

		+above(size-m)
			margin 0

		&:last-child
			margin-bottom 0




	&__showcase
		grid-area image
		margin 0 0 30px

		+above(size-m)
			margin 0

		&:last-child
			margin-bottom 0




	&__main
		grid-area main
		margin 0 0 30px

		+above(size-m)
			margin 0

		&:last-child
			margin-bottom 0




	&__footer
		grid-area footer
		margin 0 0 30px

		+above(size-m)
			margin 0
			padding 17px 0 0

		&:last-child
			margin-bottom 0



	&__illustration
		position relative
		display block
		overflow hidden
		box-shadow 0 0 14px 0 var(--shadow-dark)

		&:before
			content ''
			display block
			width 100%
			height auto
			padding 100% 0 0

			+above(size-m)
				padding 107.72% 0 0



	&__image
		position absolute
		top 0
		left 0
		display block
		width 100%
		height 100%
		object-fit scale-down
		object-position 50% 50%



	&__title
		display block
		margin 0 0 14px

		+above(size-l)
			margin 0 0 18px

		&:last-child
			margin-bottom 0



	&__note
		display block
		color var(--color-grey)
		font-size 16px
		font-weight 300



	&__filters
		margin 0 0 18px

		+above(size-l)
			margin 0 0 74px

		&:last-child
			margin-bottom 0




	&__radio-group
		margin 0 0 16px

		&:last-child
			margin-bottom 0





	&__links
		margin 0 0 30px
		font-size 14px
		line-height 1.428

		&:last-child
			margin-bottom 0






	&__link-item
		margin 0 0 10px

		&:last-child
			margin-bottom 0



	&__link
		position relative
		display inline
		vertical-align middle
		color var(--color-primary)
		font-weight 300
		text-decoration none
		background transparent
		border none
		outline none

		def-trn(opacity)

		&:hover
			opacity $hover-opacity






	&__icon-props
		margin 0 0 30px

		&:last-child
			margin-bottom 0
