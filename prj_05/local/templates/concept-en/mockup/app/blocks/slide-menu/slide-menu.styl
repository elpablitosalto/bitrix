DIR = '../blocks/slide-menu/'
IMG_DIR = DIR + 'images/'

.slide-menu
	display block
	overflow hidden auto
	height 100%
	padding 20px 20px 39px
	color var(--color-white)
	background var(--color-dark)



	&__lang-link
		display flex
		flex-wrap nowrap
		justify-content flex-end
		margin 0 0 20px

		&:last-child
			margin-bottom 0



	&__nav
		display block
		margin 0 0 20px

		&:last-child
			margin-bottom 0



	&__referrer
		display block
		margin 0 0 20px
		padding 16px 0
		border-top 1px solid var(--color-grey)
		border-bottom 1px solid var(--color-grey)

		&:last-child
			margin-bottom 0



	&__referrer-link
		display block
		color var(--color-alt)
		font-size 16px
		font-weight 700
		line-height 1.5
		text-decoration none
		text-transform uppercase
		def-trn(opacity)

		&:hover
			color var(--color-alt)
			text-decoration none
			opacity $hover-opacity



	&__contacts
		display block
		margin 32px 0 0
		padding 16px 0 0
		border-top 1px solid var(--color-grey)

		&:first-child
			margin-top 0



	&__links
		display block
		margin 0 0 16px
		line-height 1.2

		&:last-child
			margin-bottom 0



	&__link
		display block
		margin 0 0 10px

		&:last-child
			margin-bottom 0



	&__social-nav
		display block
		margin 0 0 16px

		&:last-child
			margin-bottom 0
