DIR = '../blocks/entry-grid/'
IMG_DIR = DIR + 'images/'

.entry-grid
	display block



	&__list
		display grid
		grid-template-columns repeat(auto-fill, minmax(100%, 1fr))
		grid-gap 20px
		max-width 220px
		margin 0 auto

		+above(size-s)
			grid-template-columns repeat(auto-fill, minmax(45%, 1fr))
			max-width 100%
			margin 0

		+above(size-m)
			grid-template-columns repeat(auto-fill, minmax(28%, 1fr))
			grid-gap 23px 20px

		+above(size-l)
			grid-template-columns repeat(auto-fill, minmax(21%, 1fr))



	&__item
		display block
		margin 0



	&__snippet
		height 100%



	&__load-trigger-line
		display flex
		flex-wrap nowrap
		align-items center
		justify-content center



	&__load-trigger-dot
		display none
		width 5px
		height 5px
		margin 40px 8px 0 0
		font-size 0
		background var(--color-black)
		animation-name entry-grid-loading
		animation-duration 2s
		animation-timing-function linear
		animation-iteration-count infinite

		&:nth-child(1)
			animation-delay 0

		&:nth-child(2)
			animation-delay .2s

		&:nth-child(3)
			animation-delay .4s

		&:last-child
			margin-bottom 0




	// Modifiers
	&_state
		&_loading
			.entry-grid
				&__load-trigger-dot
					display block



@keyframes entry-grid-loading
	0%
		opacity 1

	50%
		opacity 0

	100%
		opacity 1
