DIR = '../blocks/carousel-nav/'
IMG_DIR = DIR + 'images/'

.carousel-nav
	display block
	font-size 0
	line-height 0
	white-space nowrap
	pointer-events auto



	&__control
		display inline-block
		vertical-align middle
		padding 0 2px

		+above(size-m)
			padding 0 10px

		&:first-child
			padding-left 0

		&:last-child
			padding-right 0



	&__arrow
		position relative
		display block
		width 25px
		height 25px
		color var(--color-black)
		text-align center
		text-decoration none
		background var(--color-milk)
		border 1px solid #ececec
		border-radius 50%
		outline none
		opacity .5
		def-trn color, background-color, border-color, opacity

		+above(size-m)
			width 52px
			height 52px

		&:hover
			color var(--color-black)
			background-color transparent
			opacity $hover-opacity

		&:focus-visible
			color var(--color-black)
			background-color transparent
			opacity 1

		&:disabled
			color var(--color-grey)
			pointer-events none
			opacity .5

		// Modifiers
		&_type
			&_prev
				.carousel-nav
					&__arrow-label
						&:before
							transform translate(-25%, -50%) rotate(-135deg)

					&__icon
						transform rotate(180deg)

			&_next
				.carousel-nav
					&__arrow-label
						&:before
							transform translate(-75%, -50%) rotate(45deg)



	&__arrow-label
		position relative
		display block
		width 100%
		height 100%

		&:before
			content ''
			position absolute
			top 50%
			left 50%
			z-index 1
			display block
			width 12px
			height 12px
			border-top 3px solid currentColor
			border-right 3px solid currentColor



	&__icon
		display block
		width 100%
		height 100%
		fill currentColor




	&__pagination
		display inline-block
		vertical-align middle
		padding 0 4px

		&:first-child
			padding-left 0

		&:last-child
			padding-right 0



	&__pagination-element
		display inline-block
		vertical-align middle
		color var(--color-grey)
		font-size 20px
		line-height 24px



	&__current
		color var(--color-primary)



	// Modifiers
	&_position
		&_sides
			position absolute
			top 50%
			left 50%
			z-index 1
			width 100%
			transform translate(-50%, -50%)

			.carousel-nav
				&__control
					padding 0

				&__arrow
					position absolute
					top 50%
					z-index 10
					transform translate(0, -50%)

					&_type
						&_prev
							left 0

						&_next
							right 0

	&_size
		&_l
			.carousel-nav
				&__control
				&__pagination
					padding 0 8px

					&:first-child
						padding-left 0

					&:last-child
						padding-right 0

				&__arrow
					width 29px
					height 29px

	&_arrow-size
		&_l
			.carousel-nav
				&__arrow-label
					&:before
						width 12px
						height 12px
						border-width 3px 3px 0 0

	&_arrow-style
		&_solid
			.carousel-nav
				&__arrow
					width 32px
					height 32px
					padding 8px
					color var(--color-black)
					text-align center
					text-decoration none
					background #fafafa
					border 1px solid #ececec
					border-radius 50%
					outline none
					opacity .5
					def-trn color, background-color, border-color, opacity

					+above(size-m)
						width 52px
						height 52px
						padding 15px

					&:hover
						color var(--color-black)
						text-decoration none
						background #fafafa
						border 1px solid #ececec
						opacity 1

					&:focus
						color var(--color-milk)
						background-color var(--color-primary)
						border-color var(--color-primary)
						opacity 1

					&:disabled
						color var(--color-grey)
						pointer-events none
						opacity .5

					// Modifiers
					&_type
						&_prev
							.carousel-nav
								&__arrow-label
									&:before
										transform translate(-25%, -50%) rotate(-135deg)

						&_next
							.carousel-nav
								&__arrow-label
									&:before
										transform translate(-75%, -50%) rotate(45deg)