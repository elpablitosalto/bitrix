DIR = '../blocks/modal/'
IMG_DIR = DIR + 'images/'

.modal
	display none
	overflow auto
	width 100%
	padding 20px
	color var(--color-dark)
	background #fff

	+above(size-m)
		max-width 430px
		min-height auto



	&__header
		display block
		margin 0 0 16px
		text-align center

		+above(size-m)
			text-align left

		&:last-child
			margin-bottom 0



	&__content
		max-width 100%



	&__title
		display block
		margin 0 0 4px

		&:last-child
			margin-bottom 0



	&__text
		display block
		margin 0 0 32px
		font-size 14px
		font-weight 300
		line-height 1.429

		+above(size-m)
			font-size 16px
			line-height 1.5

		&:last-child
			margin-bottom 0



	&__illustration
		margin 0 0 20px
		text-align center

		&:last-child
			margin-bottom 0

		& + .modal
			&__text
				text-align center



	&__icon
		display inline-block
		vertical-align middle
		width 66px
		height 66px
		margin 0
		padding 0

		&_role
			&_error
				display none



	&__controls
		display flex
		flex-wrap wrap
		align-items flex-start
		justify-content center
		margin 0 0 20px

		&:last-child
			margin-bottom -12px



	&__control
		display block
		flex 0 1 auto
		width auto
		min-width 156px
		margin 0 12px 12px 0

		&:last-child
			margin-right 0


	// Modifiers
	&_form-state
		&_sent
			.modal
				&__header
					display none