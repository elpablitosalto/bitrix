DIR = '../blocks/section/'
IMG_DIR = DIR + 'images/'

.section
	position relative
	display block
	overflow hidden
	padding 50px 0



	&__main
		position relative
		z-index 1



	&__header
		display block
		margin 0 0 32px

		&:last-child
			margin-bottom 0

		.section
			&__text
				color var(--color-grey)
				font-size 15px
				font-weight 300
				line-height 1.533

				+above(size-l)
					font-size 19px
					line-height 1.21



	&__title
		margin 0 0 19px

		&:last-child
			margin-bottom 0



	&__content
		display block



	&__panel
		position absolute
		left 50%
		bottom 0
		width 100%
		max-width 320px
		padding 0 42px 0 33px
		transform translate(-50%, 50%)

		+above(size-m)
			max-width 1440px
			padding 0 40px

		+above(size-xl)
			padding 0 91px 0 73px



	&__row
		display block
		margin 0 0 40px

		+above(size-l)
			display flex
			flex-wrap nowrap
			margin -30px -10px 10px

		&:last-child
			margin-bottom 0

			+above(size-l)
				margin-bottom -30px



	&__col
		display block
		margin 0 0 24px

		+above(size-l)
			flex 1 1 auto
			width auto
			max-width 100%
			padding 30px 10px

		&:last-child
			margin-bottom 0



	// Modifiers
	&_style
		&_decorated
			background-image url('../blocks/section/images/figure.svg')
			background-repeat no-repeat
			background-position 30.3% 49.8%
			background-size 712px auto

			+above(size-l)
				background-position 92.3% 60.8%
				background-size 687px auto

			.section
				&__content
					mix-blend-mode multiply

			&-reverse
				background-image url('../blocks/section/images/figure-r.svg')
				background-repeat no-repeat
				background-position 53.3% 15.4%
				background-size 801px auto

				+above(size-l)
					background-position 26.3% 38.4%

				.section
					&__content
						mix-blend-mode multiply

		&_filled
			color var(--color-white)
			background-color var(--color-primary)

		&_milk
			background-color var(--color-milk)

		&_gradient
			box-shadow 0 0 25px 0 rgba(0, 0, 0, .15)

			.section
				&__content
					position relative

			&:after
				content ''
				position absolute
				left 0
				bottom 0
				z-index 0
				display block
				width 100%
				height 40%
				pointer-events none
				background linear-gradient(rgba(250, 250, 250, 0), var(--color-milk))

		&_full-gradient
			background linear-gradient(rgba(250, 250, 250, 0), var(--color-milk))

	&_text-style
		&_grey
			.section
				&__text
					color var(--color-grey)

	&_text-size
		&_l
			.section
				&__text
					font-size 15px
					font-weight 300
					line-height 1.533

					+above(size-l)
						font-size 19px
						line-height 1.21

	&_role
		&_features
			z-index 1
			padding 50px 0 82px

			+above(size-l)
				padding 60px 0 96px

			.section
				&__header
					margin 0 0 81px

					+above(size-l)
						margin 0 0 84px

					&:last-child
						margin-bottom 0

		&_product-features
			z-index 1
			padding 43px 0 80px

			+above(size-l)
				padding 60px 0 90px

			.section
				&__header
					margin 0 0 55px

					+above(size-l)
						margin 0 0 75px

					&:last-child
						margin-bottom 0

				&__title
					+below(size-l - 1)
						margin 0 0 38px

					&:last-child
						+below(size-l - 1)
							margin-bottom 0

				&__text
					+below(size-l - 1)
						font-size 12px
						line-height 1.75

		&_catalog
			padding 118px 0 61px

			+above(size-l)
				padding 100px 0 113px

			.section
				&__header
					margin 0 0 45px

					+above(size-l)
						margin 0 0 64px

					&:last-child
						margin-bottom 0

		&_info-panels
			padding 30px 0 32px

			+above(size-l)
				padding 60px 0 88px

			.section
				&__header
					margin 0 0 39px

					+above(size-l)
						margin 0 0 62px

					&:last-child
						margin-bottom 0

				&__title
					margin 0 0 12px

					+above(size-l)
						margin 0 0 19px

					&:last-child
						margin-bottom 0

		&_products
			padding 55px 0 36px

			+above(size-l)
				padding 110px 0 64px

			.section
				&__header
					margin 0 0 26px

					+above(size-l)
						margin 0 0 80px

					&:last-child
						margin-bottom 0

					.section
						&__text
							+below(size-l - 1)
								font-size 12px
								line-height 1.75

				&__title
					margin 0 0 27px

					+above(size-l)
						margin 0 0 38px

					&:last-child
						margin-bottom 0


		&_gallery
			padding 74px 0 19px

			+above(size-l)
				padding 45px 0 0

			.section
				&__header
					margin 0 0 37px

					+above(size-l)
						margin 0 0 52px

					&:last-child
						margin-bottom 0

		&_category-products
			padding 58px 0 42px

			+above(size-l)
				padding 74px 0 42px

			.section
				&__header
					margin 0 0 37px

					+above(size-l)
						margin 0 0 53px

					&:last-child
						margin-bottom 0

				&__title
					margin 0 0 37px

					+above(size-l)
						margin 0 0 48px

					&:last-child
						margin-bottom 0

				&__text
					max-width 995px

					+below(size-l - 1)
						font-size 12px
						line-height 1.75

		&_product-categories
			padding 31px 0 21px

			+above(size-l)
				padding 67px 0 61px

			.section
				&__header
					margin 0 0 19px

					+above(size-l)
						margin 0 0 37px

					&:last-child
						margin-bottom 0

		&_videos
			padding 36px 0 83px

			+above(size-l)
				padding 85px 0 118px

			.section
				&__header
					margin 0 0 34px

					+above(size-l)
						margin 0 0 20px

					&:last-child
						margin-bottom 0

		&_card-detail
			overflow visible
			padding 0

			+above(size-l)
				padding 128px 0 67px

		&_product-description
			.section
				&__header
					margin 0 0 28px

					+above(size-l)
						margin 0 0 24px

					&:last-child
						margin-bottom 0

				&__text
					margin 0 0 40px
					color #676767
					font-weight 400
					line-height 1.75

					+above(size-l)
						margin 0 0 36px
						line-height 1.5625

					&:last-child
						margin-bottom 0

				&__col
					margin 0 0 40px

					+above(size-l)
						margin 0

					&:first-child
						+above(size-l)
							flex-basis 64%
							margin 0 100px 0 0

						&:last-child
							margin-right 0

					&:last-child
						margin-bottom 0

		&_image-carousel
			+above(size-l)
				padding 56px 0 116px

		&_entity-grid
			.section
				&__header
					margin 0 0 16px

					&:last-child
						margin-bottom 0

				&__text
					margin 0 0 29px

					&:last-child
						margin-bottom 0

		&_lookbook-grid
			.section
				&__header
					margin 0 0 30px

					+above(size-l)
						margin 0 0 10px

					&:last-child
						margin-bottom 0

				&__title
					margin 0 0 45px

					+above(size-l)
						margin 0 0 19px

					&:last-child
						margin-bottom 0

	&_spacing
		&_none
			padding 0

		&_top
			&-none
				padding-top 0

		&_bottom
			&-none
				padding-bottom 0