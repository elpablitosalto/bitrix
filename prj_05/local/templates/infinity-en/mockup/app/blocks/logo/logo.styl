DIR = '../blocks/logo/'
IMG_DIR = DIR + 'images/'

.logo
	display block
	color inherit
	text-decoration none

	def-trn(opacity)

	&:hover
		color inherit
		text-decoration none
		opacity $hover-opacity



	&__image
		display block
		width 100%



	&__figure
		display block
		width 100%
		height auto
		fill currentColor