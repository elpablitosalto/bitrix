DIR = '../blocks/info-panel/'
IMG_DIR = DIR + 'images/'

.info-panel
	display block



	&__wrapper
		display block

		+above(size-m)
			display flex
			flex-wrap nowrap



	&__illustration
		position relative
		display block
		min-height 160px
		background var(--color-grey)

		+above(size-m)
			flex 0 1 50%
			width 50%
			max-width 50%
			min-height 320px

		+above(size-l)
			min-height 400px

		&:before
			content ''
			display block
			width 100%
			height auto
			padding 67% 0 0



	&__image
		position absolute
		top 0
		left 0
		z-index 1
		display block
		width 100%
		height 100%
		margin 0
		padding 0
		object-fit cover



	&__content
		position relative
		display flex
		flex-direction column
		flex-wrap nowrap
		align-items center
		justify-content center
		padding 40px 20px 0

		+above(size-m)
			flex 0 1 50%
			align-items flex-start
			width 50%
			max-width 50%
			padding 32px 32px 32px 64px

		+above(size-xl)
			padding 32px 70px 32px 112px



	&__title
		position absolute
		left 0
		bottom 100%
		z-index 2
		display block
		clip-path polygon(0 0, 100% 0, calc(100% - 18px) 100%, 0 100%)
		flex 0 0 auto
		min-width 130px
		padding 0 29px 0 18px
		color var(--color-white)
		font-size 23px
		font-weight 700
		line-height 1.761
		background var(--color-primary)
		transform translate(-10px, 44%)

		+above(size-m)
			position relative
			left auto
			bottom auto
			clip-path polygon(18px 0, 100% 0, calc(100% - 18px) 100%, 0 100%)
			min-width auto
			margin 0 0 17px
			padding 0 40px
			transform translate(-36px, 0)

		+above(size-l)
			line-height 1.783

		&:last-child
			margin-bottom 0



	&__text
		display block
		flex 0 0 auto
		width 100%
		max-width 386px
		margin 0 0 27px
		color #505050
		font-size 12px
		font-weight 400
		line-height 1.75

		+above(size-m)
			margin 0 0 12px

		&:last-child
			margin-bottom 0



	&__link-group
		display block
		flex 0 0 auto
		width 100%
		margin 0 0 20px
		font-size 12px
		line-height 1.6

		+above(size-m)
			line-height 1.2

		&:last-child
			margin-bottom 0



	&__links
		display flex
		flex-wrap wrap
		margin 0
		padding 0
		list-style none



	&__link-item
		display block
		flex 0 1 50%
		width 50%
		max-width 50%
		margin 0
		padding 15px 0 0 20px

		+above(size-m)
			padding 15px 20px 0 0

		&:nth-child(1)
		&:nth-child(2)
			padding-top 0

		&:nth-child(2n - 1)
			+below(size-m - 1)
				padding-left 0



	// Modifiers
	&_layout
		&_reversed
			.info-panel
				&__wrapper
					+above(size-m)
						flex-direction row-reverse

				&__content
					+above(size-xl)
						padding 32px 112px 32px 100px

	&_links
		&_long
			.info-panel
				&__link-item
					flex-basis 100%
					width 100%
					max-width 100%
					padding-right 0
					padding-left 0

					&:nth-child(2)
						padding-top 15px