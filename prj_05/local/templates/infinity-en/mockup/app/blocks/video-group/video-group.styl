DIR = '../blocks/video-group/'
IMG_DIR = DIR + 'images/'

.video-group
	display block



	&__list
		display grid
		grid-template-columns repeat(auto-fill, minmax(100%, 1fr))
		grid-gap 36px
		margin 0

		+above(size-m)
			grid-template-columns repeat(auto-fill, minmax(45%, 1fr))
			grid-gap 20px

		+above(size-l)
			grid-template-columns repeat(auto-fill, minmax(30%, 1fr))



	&__item
		display block
		margin 0
