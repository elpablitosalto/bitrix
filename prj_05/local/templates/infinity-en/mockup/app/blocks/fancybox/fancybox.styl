DIR = '../blocks/fancybox/'
IMG_DIR = DIR + 'images/'

.fancybox
	&__slide
		padding 0

		+above(size-m)
			padding 12px

		&.has-iframe
			.fancybox
				&__content
					&.fancybox
						&__content
							width 960px
							max-width 100%
							height calc((100vw - 24px) / 1.777)
							max-height 540px
							padding 0

					& > .carousel__button.is-close
						display none



	&__container
		&:focus
			outline none



	&__content
		& > .carousel
			&__button
				&.is-close
					top 0
					right 0
					color var(--color-primary)

					+above(size-m)
						top 16px
						right 16px


		.carousel
			&__button
				width 40px
				height 40px

				svg
					width 20px
					height 20px
					stroke-width 2
					filter none

					+above(size-m)
						width 30px
						height 30px



	&__carousel
		&.is-draggable
			.fancybox__slide
				.fancybox__content
					cursor default
