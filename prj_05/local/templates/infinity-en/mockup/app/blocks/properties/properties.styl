DIR = '../blocks/properties/'
IMG_DIR = DIR + 'images/'

.properties
	display block
	font-size 12px
	font-weight 300
	line-height 1.5

	+above(size-m)
		font-size 14px
		line-height 1.429



	&__list
		display block
		margin 0
		padding 0
		list-style none



	&__item
		display block
		margin 0 0 18px
		padding 0

		+above(size-m)
			margin 0 0 20px

		&:last-child
			margin-bottom 0



	&__label
		display inline-block
		vertical-align baseline
		margin 0 0 0 -.55em
		padding 0 .55em
		color var(--color-white)
		font-weight 700
		background var(--color-primary)
		transform skew(-24deg, 0)



	&__label-text
		transform skew(24deg, 0)



	&__value
		display inline
		vertical-align baseline
