DIR = '../blocks/contacts/'
IMG_DIR = DIR + 'images/'

.contacts
	display block



	&__wrapper
		display block

		+above(size-l)
			display flex
			flex-wrap nowrap



	&__main
		display block
		margin 0 0 92px

		+above(size-l)
			flex 1 1 100%
			width 100%
			max-width 100%
			margin 0

		&:last-child
			margin-bottom 0



	&__form-panel
		display block
		margin 0 0 40px

		+above(size-l)
			flex 0 0 40.7%
			width 40.7%
			max-width 40.7%
			margin 0 122px

		&:first-child
			+above(size-l)
				margin-left 0

		&:last-child
			margin-bottom 0

			+above(size-l)
				margin-right 0



	&__section
		display block
		margin 0 0 17px

		+above(size-l)
			margin 0 0 58px

		&:last-child
			margin-bottom 0



	&__title
		display block
		margin 0 0 24px
		color var(--color-primary)
		font-size 27px
		font-weight 700
		line-height 1.22

		+above(size-l)
			margin 0 0 18px
			font-size 32px

		&:last-child
			margin-bottom 0



	&__text
		display block
		margin 0 0 15px
		color var(--color-grey)
		font-size 19px
		font-weight 300
		line-height 1.223

		+above(size-l)
			margin 0 0 19px

		&:last-child
			margin-bottom 0



	&__note
		display block
		margin 0 0 32px
		color #505050
		font-size 12px
		font-weight 400
		line-height 1.75

		&:last-child
			margin-bottom 0



	&__subtitle
		display block
		margin 0 0 22px

		&:last-child
			margin-bottom 0



	&__group
		display flex
		flex-wrap nowrap
		margin 0 0 6px
		padding 10px 0 0

		&:last-child
			margin-bottom 0



	&__icon-wrapper
		display block
		flex 0 0 auto
		width auto
		margin 0 10px 0 0
		padding 2px 0
		font-size 0

		&:last-child
			margin 0



	&__icon
		display block
		width 16px
		height 16px
		fill currentColor



	&__list
		display block
		flex 1 1 100%
		align-self center
		margin 0
		padding 0
		list-style none
		font-size 14px
		font-weight 300
		line-height 1.429



	&__item
		display block
		margin 0 0 8px
		padding 0

		&:last-child
			margin-bottom 0



	&__link
		color inherit
		text-decoration none
		def-trn opacity

		&:hover
			color inherit
			text-decoration none
			opacity .8

		&:focus
			color inherit
			text-decoration none
			outline none
			opacity .7

		.contacts
			&__label
				margin 0 0 0 12px

				&:first-child
					margin-left 0



	&__label
		margin 0 0 16px

		&:last-child
			margin-bottom 0



	&__links
		display block

		+above(size-m)
			display flex
			flex-wrap nowrap
			align-items flex-start



	&__link-item
		display block
		margin 0 0 16px

		+above(size-m)
			flex 0 1 auto
			width auto
			max-width auto
			margin 0 44px 12px 0

		&:last-child
			margin-right 0

			+below(size-m - 1)
				margin-bottom 0