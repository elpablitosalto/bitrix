DIR = '../blocks/product-preview/'
IMG_DIR = DIR + 'images/'

.product-preview
	display block



	&__wrapper
		display block

		+above(size-m)
			display flex
			flex-wrap nowrap
			align-items center



	&__showcase
		display block
		margin 0 0 24px

		dashed-border(1, 5, #BFBFBF)

		+above(size-m)
			flex 0 1 49%
			width 49%
			max-width 49%
			margin 0

		&:last-child
			margin-bottom 0



	&__illustration
		position relative
		display block
		width 100%
		border 1px solid transparent

		&:before
			content ''
			display block
			width 100%
			height auto
			padding 100% 0 0


	&__image
		position absolute
		top 0
		left 0
		z-index 1
		display block
		width 100%
		height 100%
		object-fit cover



	&__info
		display block
		padding 0 10px

		+above(size-m)
			flex 0 1 426px
			width 426px
			max-width 50%
			margin 0 auto
			padding 26px 20px 0 31px



	&__description
		display block
		margin 0 0 18px
		font-size 12px
		font-weight 400
		line-height 1.5

		+above(size-m)
			margin 0 0 21px
			font-size 16px
			line-height 1.25

		&:last-child
			margin-bottom 0



	&__properties
		display block
		margin 0 0 25px

		+above(size-m)
			margin 0 0 37px

		&:last-child
			margin-bottom 0



	&__controls
		display block



	&__control
		display block

		+above(size-m)
			display inline-block
			vertical-align middle
			min-width 231px