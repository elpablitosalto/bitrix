DIR = '../blocks/header/'
IMG_DIR = DIR + 'images/'

.header
	position relative
	display block
	color var(--color-dark)
	background var(--color-white)
	def-trn(background)



	&__container
		display flex
		flex-wrap nowrap
		align-items center



	&__top
		position relative
		display none
		padding 9px 0 10px
		background var(--color-milk)

		+above(size-l)
			display block



	&__main
		position relative
		display block
		padding 8px 0

		+above(size-l)
			padding 20px 0 8px

		& > .header
			&__container
				+above(size-l)
					align-items flex-start



	&__panel
		position relative
		display none
		padding 0
		color var(--color-white)
		background var(--color-primary)

		+above(size-l)
			display block

		& > .header
			&__container
				align-items stretch



	&__lang-nav
		display block
		flex 0 0 180px
		width 180px
		min-width 180px
		margin 0 20px 0 0

		& + .header
			&__simple-nav
				padding-right 200px

		&:last-child
			margin-right 0



	&__simple-nav
		display block
		flex 0 1 auto
		width auto
		margin 0 auto



	&__burger
		display block
		flex 0 0 24px
		width 24px
		max-width 24px
		margin 0 16px 0 0

		+above(size-l)
			display none

		& ~ .header
			&__logo
				+below(size-l - 1)
					padding-right 40px



	&__logo
		display block
		flex 0 1 auto
		width 178px
		margin 0 auto
		color var(--color-primary)

		+above(size-m)
			width 250px

		+above(size-l)
			margin 0

		+above(size-xl)
			margin 0 0 0 -24px

		+above(size-xxl)
			margin 0 0 0 -46px



	&__contacts
		display none
		flex 0 1 auto
		flex-direction column
		flex-wrap nowrap
		align-items flex-end
		margin 0 0 0 auto
		padding 0 0 6px 40px

		+above(size-l)
			display flex



	&__links
		display block
		margin 0 0 18px
		line-height 1.2

		&:last-child
			margin-bottom 0



	&__link
		display block
		margin 0 0 10px

		&:last-child
			margin-bottom 0



	&__social-nav
		display block
		margin 0 0 18px

		&:last-child
			margin-bottom 0



	&__nav
		flex 1 1 auto
		max-width calc(100% - 243px)



	&__referrer
		position relative
		display flex
		clip-path polygon(11% 0, 100% 0, 89% 101%, 0 101%)
		flex 0 0 auto
		flex-wrap nowrap
		column-gap 7px
		align-items center
		justify-content center
		width 243px
		color var(--color-primary)
		background var(--color-white)

		+above(size-xl)
			margin 0 -35px 0 35px



	&__referrer-text
		display block
		flex 0 1 auto
		font-size 16px
		font-weight 300
		line-height 1.2
		text-transform uppercase



	&__referrer-logo
		&:before
			content ''
			position absolute
			top 0
			left 0
			width 100%
			height 100%



	// Modifiers
	&_style
		&_shadowed
			box-shadow 0 0 50px 50px rgba(0, 0, 0, .25)