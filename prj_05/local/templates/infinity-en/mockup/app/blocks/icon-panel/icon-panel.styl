DIR = '../blocks/icon-panel/'
IMG_DIR = DIR + 'images/'

.icon-panel
	display block
	padding 0 10px

	+above(size-m)
		padding 0



	&__wrapper
		display flex
		flex-wrap nowrap



	&__illustration
		display block
		flex 0 0 auto
		width auto
		margin 0 16px 0 0

		+above(size-l)
			margin 0 20px 0 0

		&:last-child
			margin-right 0



	&__image
	&__icon
		display block
		width auto
		height 66px
		margin 0

		+above(size-l)
			height 85px



	&__icon
		width 66px
		fill var(--color-primary)

		+above(size-l)
			width 85px



	&__info
		display block
		flex 0 1 auto

		+above(size-l)
			padding 5px 0



	&__title
		display block
		margin 0 0 15px
		font-size 16px
		font-weight 700
		line-height 1.223

		+above(size-l)
			font-size 20px

		&:last-child
			margin-bottom 0



	&__text
		display block
		margin 0 0 16px
		font-size 12px
		font-weight 400
		line-height 1.223

		+above(size-l)
			font-size 14px

		&:last-child
			margin-bottom 0

		p:not([class])
			margin 0



	// Modifiers
	&_type
		&_compact
			padding 0

			.icon-panel
				&__illustration
					margin 0 10px 0 0

					&:last-child
						margin-right 0

				&__icon
				&__image
					width 25px

				&__icon
					height 25px

				&__info
					padding 2px 0

				&__title
					margin 0 0 6px

					&:last-child
						margin-bottom 0

				&__text
					color #676767