DIR = '../blocks/banner/'
IMG_DIR = DIR + 'images/'

.banner
	display block
	text-decoration none



	&__picture
		position relative
		display block

		&:before
			content ''
			display block
			width 100%
			height  auto
			padding 200px 0 0

			+above(size-m)
				padding 34.6% 0 0



	&__image
		position absolute
		top 0
		left 0
		display block
		width 100%
		height 100%
		object-fit cover



	// Modifiers
	&_height
		&_auto
			.banner
				&__picture
					&:before
						display none

				&__image
					position static

	&_type
		&_a
			.banner
				&__picture
					&:before
						padding 31.2% 0 0
