									text: "<p>В капсуле Активаторы: 1,5%, 3%, 6%, 9%, 12%</p>",
								},
								{
									icon: 'd6.png',
									simpleTitle: true,
									title: "Комфортен в работе:",
									text: "<p>Активирует рождение цвета, создавая смесь идеальной кремовой консистенции</p>",
								},
								{
									icon: 'd7.png',
									simpleTitle: true,
									title: "Одна линия активаторов для всех процедур изменения цвета:",
									text: "<p>Раскрывает все возможности красителя, гарантирует 100% попадание в палитру</p>",
								},
							]
						})._size_m

	+e.breadcrumbs
