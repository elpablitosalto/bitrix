			pagination: true,
			items: [
				{
					image: '3.jpg',
					sources: [
						{
							src: '3-m.jpg',
							media: '(max-width: 479px)',
							type: 'image/jpg'
						}
					],
					attr: {
						class: '_height_auto'
					}
				},
				{
					image: '3.jpg',
					sources: [
						{
							src: '3-m.jpg',
							media: '(max-width: 479px)',
							type: 'image/jpg'
						}
					],
					attr: {
						class: '_height_auto'
					}
				},
				{
					image: '3.jpg',
					sources: [
						{
							src: '3-m.jpg',
							media: '(max-width: 479px)',
							type: 'image/jpg'
						}
