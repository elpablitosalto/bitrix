extends /layouts/default/default.pug

block head
	- var pageTitle = 'Detail | Hair Infinity';
	- var pageDescription = ' Hair Infinity';
	- var pageKeywords = 'hair, infinity';

	- var fileName = 'detail-single.html';
	- var bodyClass = '';
	- var headerClass = '';
	- var headerWrapperClass = '_style_shadowed __header-wrapper';

block content
	+e.banner-carousel
		+banner-carousel({
			pagination: true,
			items: [
				{
					image: '2.jpg',
					sources: [
						{
							src: '2-m.jpg',
							media: '(max-width: 479px)',
							type: 'image/jpg'
						}
					],
					attr: {
						class: '_height_auto'
					}
				},
				{
					image: '2.jpg',
					sources: [
						{
							src: '2-m.jpg',
							media: '(max-width: 479px)',
							type: 'image/jpg'
						}
					],
					attr: {
						class: '_height_auto'
					}
				},
				{
					image: '2.jpg',
					sources: [
						{
							src: '2-m.jpg',
							media: '(max-width: 479px)',
							type: 'image/jpg'
						}
					],
					attr: {
						class: '_height_auto'
					}
				},
			]
		})

	+e.section
		+section()._style_filled._role_features
			+e.content
				.page__container
					+e.icon-panel-group
						+icon-panel-group({
							items: [
								{
									icon: 'd1.png',
									simpleTitle: true,
									title: "Высокое качество окрашивания:",
									text: "<p>Стойкий цвет</p><p>100% закрашивание седины</p>",
								},
								{
									icon: 'd2.png',
									simpleTitle: true,
									title: "Уникальный состав:",
									text: "<p>Комплекс Keratin infusion+ Sheа butter эффективно застраивает пустоты в кортексе, не только возвращая волосу натуральную структуру, но и надежно фиксируя пигмент,  питает и увлажняет волосы, обеспечивая силу и блеск</p>",
								},
								{
									icon: 'd3.png',
									simpleTitle: true,
									title: "Широкая палитра:",
									text: "<p>112 оттенков в палитре</p><p>8 оттенков 12 ряда</p><p>6 оттенков Х/00 (5-10 УГТ)</p><p>7 микс тонов</p>",
								},
								{
									icon: 'd4.png',
									simpleTitle: true,
									title: "Гибридная формула:",
									text: "<p>Синергия аммиачного компонента и аминоспиртов в формуле позволяют создавать стойкие интенсивные оттенки, уменьшая нагрузку на структуру волоса</p>",
								},
							]
						})._size_m

	+e.breadcrumbs
