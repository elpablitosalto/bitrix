DIR = '../blocks/header/'
IMG_DIR = DIR + 'images/'

.header
	position relative
	display block



	&__top
		position relative
		z-index 2
		height 30px
		color var(--color-black)
		text-align center
		background var(--color-yellow)



	&__top-wrapper
		padding 8px 0
		font-size 12px
		line-height 14.09px
		text-align center

		+above(size-m)
			font-size 14px




	&__main
		position relative
		z-index 1

		+above(size-l)
			display block



	&__contact-group
		display none

		+above(size-xxl)
			display block
			margin 0 50px 5px 0



	&__contact
		text-align center

		&_type
			&_control
				width 100%
				min-width 165px
				margin-top 9px



	&__link
		color var(--color-white)
		font-family Raleway
		font-size 18px
		font-weight 900
		font-style normal
		line-height 21px
		text-align center
		font-variant-numeric lining-nums
		text-decoration none

		&_size
			&_s
				font-size 12px
				line-height 14.09px



	&__geo-selector
		display none

		+above(size-xxl)
			display block
			margin 17px 49px 0 0



	&__navigations
		+above(size-m)
			display flex
			flex 1
			flex-direction row-reverse
			gap 33.45px
			align-items center

		+above(size-xxl)
			display block



	&__icon-controls
		+above(size-xxl)
			margin-bottom 7px



	&__nav
		margin-bottom 14px



	&__main-wrapper
		position relative
		display flex
		flex-wrap nowrap
		align-items center
		padding 20px 0

		+above(size-xxl)
			align-items flex-start
			padding 33px 0 42px



	&__burger
		display block
		flex 0 0 40px

		+above(size-xxl)
			display none



	&__logo
		display block
		flex-basis 131px
		width 131px
		max-width 131px
		margin-right auto

		+above(size-m)
			margin-right 33.45px

		+above(size-l)
			flex-basis 214px
			width 214px
			max-width 214px

		+above(size-xxl)
			margin 0 72px 0 0



	&__search
		display none
		flex 1 1 auto
		width auto

		+above(size-m)
			display block
			width 250px
			min-width 250px

		+above(size-l)
			min-width 400px

		+above(size-xxl)
			width auto


	&__search-trigger
		display block

		+above(size-l)
			display none


	// Modifiers

	&_state
		&_fixed
			position fixed
			top 0
			left 0
			width 100%
			box-shadow 0 4px 12px rgba(60, 60, 59, .12)

			.header
				&__top
					display none

				&__icon-controls
					+above(size-l)
						padding 0 15px

				&__fixed-auth
					+above(size-l)
						display block
