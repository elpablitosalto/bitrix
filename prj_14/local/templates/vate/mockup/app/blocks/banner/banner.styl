DIR = '../blocks/banner/'
IMG_DIR = DIR + 'images/'

.banner
	position relative
	display flex
	min-height 375px

	+above(size-m)
		display block
		min-height initial

	&::before
		content ''
		position absolute
		top -10px
		left 0
		z-index 10
		width 100%
		height 35%
		background linear-gradient(0deg, #000 0%, rgba(165, 165, 165, 0) 100%)
		transform rotate(180deg)

	&::after
		content ''
		position absolute
		left 0
		bottom 0
		z-index 10
		width 100%
		height 35%
		background linear-gradient(0deg, #000 24.4%, rgba(0, 0, 0, 0) 100%)



	&__container
		position relative
		flex 1



	&__main
		position absolute
		left 50%
		bottom 0
		z-index 20
		display flex
		flex-direction column
		justify-content space-between
		width 100%
		max-width containers.default.maxWidth
		margin 0 auto
		padding 0 0 60px
		transform translate(-50%, 0)

		+above(340px)
			padding 0 20px 60px

		+above(size-m)
			padding 0 10px 40px


	&__content
		position relative
		display flex
		flex-direction column
		gap 50px
		justify-content space-between



		+above(size-m)
			flex-direction row
			gap 0
			padding 0 40px



	&__text
		max-width 612px



	&__picture
		max-height 100%



	&__image
		display block
		width 100%
		max-width 100%
		height 450px
		object-fit cover

		+above(size-m)
			height 366px

		+above(size-xxl)
			height 570px



	&__controls
		display flex



	&__control
		width 100%
		max-width 188px

		+above(size-m)
			min-width 188px


		+above(size-xxl)
			min-width 300px



	&__title
		position relative
		margin-bottom 15px

		+above(size-m)
			margin-bottom 10px
			padding 0 40px



	&__arrows
		position absolute
		left 0
		bottom 50%
		display none
		width 100%
		transform translate(0, -50%)

		+above(size-m)
			display block

	&__image
		max-width 100%


	&_indent
		&_s
			.banner
				&__main
					padding-bottom 73px

					+above(size-m)
						padding-bottom 45px

					+above(size-xxl)
						padding-bottom 148px