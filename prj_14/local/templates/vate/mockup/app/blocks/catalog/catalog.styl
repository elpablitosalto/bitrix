DIR = '../blocks/catalog/'
IMG_DIR = DIR + 'images/'

.catalog
	display block


	&__content
		display block

		+above(size-xxl)
			display flex
			flex-wrap nowrap



	&__aside
		position fixed
		top 0
		left 0
		z-index 600
		display block
		width 100%
		height 100%
		background rgba(0, 0, 0, .65)
		transform translate(-110%, 0)
		def-trn transform

		+above(size-xxl)
			position sticky
			z-index 0
			overflow visible
			flex 0 1 25%
			width 25%
			max-width 25%
			height auto
			padding 0 39px 0 0
			background transparent
			transform none



	&__filters
		height 100%



	&__main
		display block

		+above(size-xxl)
			flex 0 1 830px



	&__pagination
		margin-top 24px

		+above(size-l)
			margin-top 65px



	&__filter-panel
		display flex
		flex-wrap wrap
		align-items center
		margin 0 0 13px

		+above(size-xxl)
			margin 0 0 40px

		&:last-child
			margin-bottom 0



	&__filter-trigger
		display block
		flex 0 1 auto
		margin 0 0 0 auto

		+above(size-xxl)
			display none



	&__cart-panel
		position relative
		display flex
		overflow hidden
		flex 1 1 100%
		align-items center
		justify-content space-between
		order 3
		width 100%
		height 0
		margin 0

		+above(size-l)
			display flex
			flex-wrap nowrap
			align-items center
			padding 0 27px
			border-radius 20px

		// Modifiers

		&_state
			&_shown
				height auto
				margin-top 20px
				padding-top 15px
				padding-bottom 15px

				+above(size-l)
					border 1px solid var(--color-gray)

				&:first-child
					margin-top 0



	&__check
		display block

		+above(size-s)
			flex 0 1 auto
			width auto
			margin 0 auto 0 0
			padding 0 15px 0 0

		&:last-child
			margin 0
			padding 0



	&__control
		display block
		min-width 144px

		+above(size-s)
			flex 0 0 auto
			min-width 194px



	&__fast-filter
		display none
		flex 1 1 100%
		order 2
		width 100%
		max-width 100%
		margin-top 20px

		+above(size-m)
			display block


	&__filter-group
		display flex
		flex 1 1 100%
		flex-wrap wrap
		gap 20px
		align-items center
		justify-content space-between
		order 1
		width 100%
		max-width 100%

		+above(size-m)
			justify-content flex-start



	&__header
		display flex
		align-items center
		margin-bottom 18px



	&__layout-group
		display none
		flex 0 0 auto
		margin 0 0 0 auto

		+above(size-m)
			display block

		&_hidden
			&_m
				display block
				margin 0 0 0 22px

				+above(size-m)
					display none




	&__text
		padding 32px 0

		&:first-child
			padding-top 0

		&:last-child
			padding-bottom 0



	// Modifiers

	&_filters
		&_open
			.catalog
				&__aside
					transform translate(0, 0)

	&_cart-panel
		&_shown
			.catalog
				&__cart-panel
					margin-top 20px
					padding-top 15px
					padding-bottom 15px

					&:first-child
						margin-top 0