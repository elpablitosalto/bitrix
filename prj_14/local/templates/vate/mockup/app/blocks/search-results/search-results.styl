DIR = '../blocks/search-results/'
IMG_DIR = DIR + 'images/'

.search-results
	position relative
	display block
	overflow hidden
	width 100%
	padding 5px 15px 15px
	background var(--color-primary)
	border none
	border-radius 10px



	&__message
		display none
		padding 15px



	&__wrapper
		display flex
		flex-direction column
		gap 10px

		+above(size-l)
			flex-direction row
			align-items center



	&__control
		margin-top 17px



	&__matches
		display block



	&__list
		display block
		margin 0
		padding 0
		list-style none



	&__link
		display flex
		gap 10px
		align-items center
		width 100%
		padding 10px 0 4px
		color var(--color-black)
		font-size 12px
		font-weight 700
		text-decoration none
		background transparent
		border none
		outline none
		def-trn color

		&:hover
			text-decoration none
			opacity .7

		&:focus
			text-decoration none
			outline none
			opacity .7



	&__name
		font-size 14px
		font-weight 700
		line-height 130%



	&__price
		flex 0 0 auto
		width fit-content
		color var(--color-black)
		font-size 14px
		border-radius 10px

		+above(size-l)
			padding 5px 10px
			color var(--color-white)
			background var(--color-gray)



	&__message
		padding 8px 28px 8px 6px
		color var(--color-black)
		font-size 12px
		text-decoration none
		background transparent



	&__image
		max-width 60px



	&__item
		display block
		margin 0
		padding 0
		border-bottom 1px solid var(--color-gray)

		// &:last-child
		// 	border-bottom none



	&_state
		&_no-results
			padding 7px 15px

			.search-results
				&__message
					display block

				&__matches
					display none

				&__control
					display none

	&_styleless
		padding 0
		background transparent

	&_content
		&_s
			.search-results
				&__control
					display none