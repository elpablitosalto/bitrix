DIR = '../blocks/info-grid/'
IMG_DIR = DIR + 'images/'

.info-grid
	display block

	&__container
		display grid
		grid-template-columns repeat(2, 1fr)
		gap 25px 20px


		+above(size-m)
			grid-template-columns repeat(4, 1fr)
			gap 25px



	&__text
		max-width 104px
		color #000
		font-family Raleway
		font-size 11px
		font-weight 700
		font-style normal
		line-height 14px
		text-align center

		+above(size-xxl)
			max-width 180px
			font-size 16px
			line-height 21px



	&__icon
		display block



	&__content
		display flex

		+above(size-m)
			flex-direction column



	&__value
		font-family Raleway
		font-size 20px
		font-weight 900
		font-style normal
		line-height normal
		background var(--color-secondary)
		-webkit-background-clip text
		background-clip text
		font-variant-numeric lining-nums
		-webkit-text-fill-color transparent

		+above(size-xxl)
			font-size 47px


	&__unit
		color var(--color-black)
		font-family Raleway
		font-size 20px
		font-weight 800
		font-style normal
		line-height 130%

		+above(size-m)
			font-size 24px



	&__item
		display flex
		flex-direction column
		gap 17px
		align-items center
		justify-content flex-end
		padding 14px 0 10.8px
		color var(--color-black)
		text-align center
		background var(--color-white)
		border-radius 15px
		box-shadow var(--shadow-primary)


		+above(size-m)
			gap 8.2px
			min-height 120px
			padding 10.8px
			border-radius 30px

		+above(size-xxl)
			gap 17px
			min-height 200px
			padding 20px

		&_size
			&_l
				display flex
				grid-area 3 / 1 / 3 / 3
				align-items initial
				justify-content center
				margin auto 0
				padding 30px 33px 28px

				+above(size-m)
					grid-area 2 / 1 / 3 / 5
					padding 28px 30px 29px 18px

			&_m
				grid-column span 6

		&_style
			&_filled
				gap 25px
				background var(--color-secondary)

	&_size
		&_secondary
			.info-grid
				&__container
					display grid
					grid-template-columns repeat(12, minmax(8px, 1fr))
					gap 17px

					+above(size-xs)
						grid-template-columns repeat(12, minmax(12px, 1fr))

					+above(size-m)
						grid-template-columns repeat(12, minmax(40px, 1fr))
						gap 20px

					+above(size-xxl)
						grid-template-columns repeat(12, minmax(75px, 1fr))

				&__text
					max-width unset
					font-size 12px

					+above(size-xxl)
						font-size 16px

				&__item
					grid-column span 3

					&_layout
						&_secondary
							flex-direction column
							gap 5px
							justify-content center
							min-height 0
							padding 30px 22.5px

							+above(size-m)
								flex-direction row
								gap 25px

					&_size
						&_s
							grid-column span 5

							+above(size-m)
								grid-column span 3

						&_m
							grid-column span 5

							+above(size-m)
								grid-column span 4

						&_xl
							grid-column span 7

							+above(size-m)
								grid-column span 5

					&_size-m
						&_s
							grid-column span 7

							+above(size-m)
								grid-column span 3

						&_xl
							grid-column span 5

							+above(size-m)
								grid-column span 5

						&_m
							grid-column span 7

							+above(size-m)
								grid-column span 4