DIR = '../blocks/check-elem/'
IMG_DIR = DIR + 'images/'

.check-elem
	position relative
	display inline-block
	font-size 14px
	line-height 1.286
	cursor pointer




	&__input
		position absolute
		overflow hidden
		clip rect(0 0 0 0)
		width 1px
		height 1px
		margin -1px
		padding 0
		border none
		opacity .01
		transform scale(.001)

		&[type='radio']
			& + .check-elem
				&__label
					padding 1px 0 1px 26px

					&::before
						top 10px
						width 16px
						height 16px
						border 1px solid var(--color-black)
						border-radius 50%

					&::after
						top 10px
						left 8px
						width 8px
						height 8px
						color var(--color-black)
						background transparent
						border 1px solid var(--color-black)
						border-radius 50%
						transform translate(-50%, -50%)

			&:checked
				& + .check-elem
					&__label
						&::before
							background-color transparent
							border-color var(--color-black)

						&::after
							opacity 1

			&:hover
			&:focus
			&:active
				&:not(:disabled)
					& + .check-elem
						&__label
							&::before
								border-color var(--color-black)

		&:hover
		&:focus
		&:active
			&:not(:disabled)
				& + .check-elem
					&__label
						&::before
							border-color var(--color-black)

		&:checked
			& + .check-elem
				&__label
					&::before
						background-color transparent
						border-color var(--color-black)

					&::after
						opacity 1

		&:disabled
			pointer-events none

			& + .check-elem
				&__label
					pointer-events none
					opacity .5

		// Modifiers

		&_state
			&_error
				& + .check-elem
					&__label
						&::before
							border-color var(--color-red)



	&__count
		height auto
		padding 3px 2.5px
		color #9c9c9c
		background rgba(255,255,255, .2)
		border-radius 5px



	&__label
		position relative
		display inline-block
		// gap 10px
		// align-items center
		// justify-content space-between
		padding 3px 0 3px 30px
		font inherit
		line-height inherit
		def-trn color

		&::before
			content ''
			position absolute
			top 50%
			left 0
			display block
			box-sizing border-box
			width 20px
			height 20px
			background transparent
			border 2px solid var(--color-black)
			border-radius 5px
			transform translate(0, -50%)
			def-trn background-color, border-color

		&::after
			content ''
			position absolute
			top 50%
			left 0
			display block
			box-sizing border-box
			width 16px
			height 7px
			color var(--color-black)
			border-left 2px solid currentColor
			border-bottom 2px solid currentColor
			opacity 0
			transform translate(10%, -75%) rotate(-45deg)
			def-trn color, opacity


	&__city
		display block
		margin-bottom 5px
		color var(--color-black)
		font-size 16px
		font-weight 900
		line-height 25px

	&__address
		color var(--color-black)
		line-height 21px
	// Modifiers

	&_style
		&_light
			.check-elem
				&__input
					&:hover
					&:focus
					&:active
						&:not(:disabled)
							& + .check-elem
								&__label
									&::before
										border-color var(--color-white)

					&:checked
						& + .check-elem
							&__label
								&::before
									background-color transparent
									border-color var(--color-white)

				&__label
					&::before
						border-color var(--color-white)

					&::after
						border-color var(--color-white)

		&_muted
			.check-elem
				&__input
					&:hover
					&:focus
					&:active
						&:not(:disabled)
							& + .check-elem
								&__label
									&::before
										border-color var(--color-muted)

					&:checked
						& + .check-elem
							&__label
								&::before
									background-color transparent
									border-color var(--color-muted)

				&__label
					&::before
						border-color var(--color-muted)

					&::after
						border-color var(--color-muted)

		&_primary
			.check-elem
				&__input
					&:hover
					&:focus
					&:active
						&:not(:disabled)
							& + .check-elem
								&__label
									&::before
										border-color var(--color-yellow)

									&::after
										border-color var(--color-yellow)

					&:checked
						& + .check-elem
							&__label
								&::before
									background-color transparent
									border-color var(--color-yellow)

								&::after
									border-color var(--color-yellow)

				&__label
					padding 3px 0 3px 35px
					font-weight 600

					&::before
						left 0
						width 25px
						height 25px
						border-color var(--color-muted)
						border-radius 10px

					&::after
						left 13px
						border-color var(--color-muted)

		&_secondary
			.check-elem
				&__input
					&:hover
					&:focus
					&:active
						&:not(:disabled)
							& + .check-elem
								&__label
									&::before
									&::after
										border-color var(--color-black)

								+above(size-xxl)
									&::before
									&::after
										border-color var(--color-yellow)

					&:checked
						& + .check-elem
							&__label
								&::before
								&::after
									border-color var(--color-black)

							+above(size-xxl)
								&::before
								&::after
									border-color var(--color-yellow)

				&__label
					padding 3px 0 3px 35px
					font-weight 600

					&::before
						left 0
						width 25px
						height 25px
						border-color var(--color-black)
						border-radius 10px

					&::after
						left 13px
						border-color var(--color-black)


	&_align
		&_top
			.check-elem
				&__label
					padding 0 0 3px 32px

					&::before
						top 0
						transform none

					&::after
						top 13px


	&_size
		&_full
			width 100%


		&_s
			.check-elem
				&__label
					font-size 12px

					&::before
						width 14px
						height 14px

					&::after
						top 50%
						left -4px
						width 10px
						height 5px
						color currentColor
