DIR = '../blocks/filter-group/'
IMG_DIR = DIR + 'images/'

.filter-group
	display block
	font-size 16px
	line-height 1.25



	&__wrapper
		display flex
		flex-wrap wrap
		align-items center



	&__item
		margin 0 16px 0 0

		&:last-child
			margin 0



	&__label
		display block
		margin 0 12px 0 0



	&__link
		color inherit
		text-decoration none
		def-trn color

		&:hover
			color var(--color-muted)
			text-decoration none

		&:focus
			color var(--color-muted)
			text-decoration none

		// Modifiers

		&_state
			&_active
				color var(--color-yellow)
				text-decoration underline



	// Modifiers
