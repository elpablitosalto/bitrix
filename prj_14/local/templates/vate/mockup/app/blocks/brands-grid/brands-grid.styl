DIR = '../blocks/brands-grid/'
IMG_DIR = DIR + 'images/'

.brands-grid
	display block



	&__item
		width 100%
		text-decoration none



	&__grid
		display grid
		grid-template-columns repeat(2, 1fr)
		gap 20px

		+above(size-s)
			grid-template-columns repeat(3, 1fr)
			gap 25px

		+above(size-m)
			grid-template-columns repeat(4, 1fr)



	&__controls
		display flex
		gap 10px
		align-items center
		justify-content center
		margin-top 30px

		+above(size-m)
			margin-top 60px

	&__control
		width 100%
		max-width 154px

		+above(size-xxl)
			max-width 350px