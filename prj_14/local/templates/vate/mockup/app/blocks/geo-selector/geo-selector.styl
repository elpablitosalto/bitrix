DIR = '../blocks/geo-selector/'
IMG_DIR = DIR + 'images/'

.geo-selector
	display block

	&__trigger
		display flex
		flex-direction column
		align-items center
		text-decoration none

	&__icon
		margin-bottom 13px

	&__title
		margin-bottom 8px
		color var(--color-white)
		font-size 18px
		font-weight 900
		line-height 21.13px

	&__label
		color var(--color-white)
		font-size 12px
		font-weight 600
		line-height 14.09px
		white-space nowrap

