DIR = '../blocks/work-list/'
IMG_DIR = DIR + 'images/'

.work-list
	display block
	font-size 1.2rem



	&__list
		counter-reset workList



	&__item
		position relative
		padding 0 0 0 24px

		&::before
			content counter(workList)'.'
			counter-increment workList
			position absolute
			top 0
			left 0

		// Modifiers

		&_done
			&::after
				content ''
				display inline-block
				vertical-align baseline
				box-sizing border-box
				width 8px
				height 16px
				margin 0 0 0 8px
				color var(--color-primary)
				font-size 16px
				border-right 2px solid currentColor
				border-bottom 2px solid currentColor
				transform rotate(45deg)



	&__link
		display inline-block
		vertical-align middle
		color inherit
		text-decoration none

		def-trn(color)

		&[href='#']
			cursor default
			pointer-events none
			opacity .2

		&:hover
			color var(--color-primary)
			text-decoration none