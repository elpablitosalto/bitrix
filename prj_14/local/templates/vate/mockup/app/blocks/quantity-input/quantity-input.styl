DIR = '../blocks/quantity-input/'
IMG_DIR = DIR + 'images/'

.quantity-input
	display block



	&__wrapper
		display flex
		flex-wrap nowrap
		align-items center
		justify-content center
		padding 1px 2px
		background #252525

		+above(size-m)
			padding 5px 8px




	&__control
		display block
		flex 0 0 auto
		width auto



	&__button
		position relative
		display block
		width 18px
		height 18px
		color var(--color-white)
		font-size 0
		text-decoration none
		background transparent
		border none
		outline none
		def-trn color, background-color, border-color

		&::before
		&::after
			content ''
			position absolute
			top 50%
			left 50%
			z-index 1
			display block
			width 10px
			height 2px
			color inherit
			background currentColor
			transform translate(-50%, -50%)

			+above(size-m)
				width 16px


		&::after
			transform translate(-50%, -50%) rotate(90deg)

		&:hover
			z-index 5
			color var(--color-yellow)
			text-decoration none
			background-color transparent
			border-color var(--color-yellow)

		&:focus
			z-index 5
			color var(--color-yellow)
			text-decoration none
			background-color transparent
			border-color var(--color-yellow)

		&:active
			z-index 5
			color #fff
			text-decoration none
			background-color var(--color-yellow)
			border-color var(--color-yellow)

		&:disabled
			pointer-events none
			opacity .5

		+above(size-m)
			width 24px
			height 24px





		// Modifiers

		&_type
			&_decrease
				border-radius 2px 0 0 2px

				&::after
					display none



	&__field
		display block
		display flex
		flex 1 1 auto
		align-items center
		width auto
		height 20px

		+above(size-m)
			display block
			height initial


	&__input
		position relative
		width 17px
		height 16px
		color var(--color-white)
		font-size 12px
		font-weight 500
		line-height 18px
		text-align center
		background transparent
		border none
		outline none
		box-shadow none
		appearance textfield
		font-variant-numeric lining-nums
		def-trn border-color

		&::-webkit-outer-spin-button // @stylint ignore
		&::-webkit-inner-spin-button // @stylint ignore
			margin 0
			appearance none


		+above(size-m)
			width 30px
			height 24px
			font-size 18px
			line-height 24px


	// Modifiers
