DIR = '../blocks/catalog-filter/'
IMG_DIR = DIR + 'images/'

.catalog-filter
	display block



	&__trigger
		position relative
		display block
		width 100%
		padding 0 32px 0 0
		color var(--color-black)
		font-size 16px
		font-weight 500
		line-height 1.25
		text-align left
		text-decoration none
		letter-spacing .01em
		cursor pointer
		background transparent
		border none
		outline none

		&::after
			content ''
			position absolute
			top 50%
			right -10px
			z-index 1
			display block
			width 5px
			height 5px
			border-right 2px solid currentColor
			border-bottom 2px solid currentColor
			transform translate(50%, -50%) rotate(45deg)
			def-trn color transform

		&:hover
		&:focus
			text-decoration none
			outline none
			opacity .7

			&::after
				opacity .7


		+above(size-xxl)
			color var(--color-white)
			font-size 30px



	&__body
		display none
		padding 16px 0 0




	&__link
		color var(--color-black)
		def-trn opacity

		&:hover
			opacity .8

		+above(size-xxl)
			color var(--color-muted)



	&__check-group
		overflow hidden
		max-height 219px
		padding-right 10px
		scrollbar-color var(--color-white) var(--color-gray) // @stylint ignore
		scrollbar-width thin // @stylint ignore

		&_type
			&_scroll
				overflow hidden auto
				max-height 454px


		+above(size-l)
			&_type
				&_scroll
					max-height 563px




	&__check-item
		margin 0 0 20px
		padding 0
		cursor pointer

		&:last-child
			margin-bottom 0



	// Modifiers

	&_state
		&_open
			.catalog-filter
				&__trigger
					&::after
						transform translate(50%, -50%) rotate(225deg)

				&__body
					display block