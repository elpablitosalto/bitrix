DIR = '../blocks/partnership-panel/'
IMG_DIR = DIR + 'images/'

.partnership-panel
	display block




	&__container
		display flex
		flex-direction column
		gap 31px

		+above(size-m)
			flex-direction row
			gap 52px


	&__title
		margin-bottom 22px

		+above(size-xxl)
			margin-bottom 29px



	&__main
		+above(size-m)
			flex 0 1 400px

		+above(size-l)
			flex 0 1 508px



	&__form
		flex 1



	&__subtitle
		max-width 464px
		margin-bottom 49px
		color #000
		font-family Raleway
		font-size 20px
		font-weight 800
		font-style normal
		line-height 130%



	&__icons
		display flex
		gap 36px



	&__text
		font-size 12px

		+above(size-m)
			font-size 16px



	&__item
		position relative
		display flex
		flex-direction column
		align-items center
		max-width 100px
		line-height 21px
		text-align center



		&::after
			content ''
			position absolute
			top 31px
			right -3px
			width 15px
			height 15px
			border-right 4px solid var(--color-white)
			border-bottom 4px solid var(--color-white)
			transform translate(100%, 0%) rotate(-45deg)
			transform-origin center

		&:last-child
			&::after
				display none


		+above(size-m)
			max-width 152px
			padding 0 11px 0 0

			&:not(:first-child)
				padding 0 11px


			&::after
				top 52px


	&__icon
		display block
		max-width 90px
		max-height 90px
		margin-bottom 11px


		+above(size-l)
			max-width initial
			max-width 130px
			min-height 130px
			margin-bottom 13px



