DIR = '../blocks/label/'
IMG_DIR = DIR + 'images/'

.label
	display block
	color var(--color-white)
	font-family Raleway
	font-size 12px
	font-weight 700
	font-style normal
	line-height 150%



	&_style
		&_primary
			padding 2px 10px
			color var(--color-black)
			background var(--color-secondary)
			border-radius 30px 0 0

			+above(size-m)
				padding 6px 20px
