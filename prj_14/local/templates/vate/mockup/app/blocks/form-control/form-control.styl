DIR = '../blocks/form-control/'
IMG_DIR = DIR + 'images/'

.form-control
	display block
	height auto
	margin 0
	padding 0
	color inherit
	font inherit
	line-height 1.255
	background transparent
	border none
	border-radius 0
	outline none
	box-shadow none
	transition none

	+above(size-m)
		max-width 480px

	&__holder
		position relative
		display block
		margin 0
		padding 0
		font inherit


	&__icon
		position absolute
		top 50%
		right 22px
		display none
		transform translate(0%, -50%)


	&__label
		display block
		margin 0 0 4px
		color inherit
		font-size 16px
		line-height 1.286
		text-align left

		&:last-child
			margin-bottom 0

	&__field
	&__check-group
		position relative
		display block

	&__input
	&__textarea
	&__select
	.choices__inner
		display block
		width 100%
		height 50px
		padding 0 19.59px
		color var(--color-black)
		font-size 16px
		font-weight 600
		line-height 24px
		background var(--color-white)
		border none
		border-radius 10px
		outline none
		def-trn border-color


		placeholder(var(--color-gray), 16px)

		&:disabled
			cursor not-allowed
			opacity .7

		&_state
			&_invalid
				border 1px solid var(--color-red)

				placeholder(var(--color-red), 16px)

				~ .form-control__icon_error
					display block

				&:focus
					border-color var(--color-red)

		&.just-validate-success-field
			~ .form-control__icon_success
				display block

	&__message
		display none

		// Modifiers




	&__input
		&[type='number']
			appearance textfield

			&::-webkit-outer-spin-button // @stylint ignore
			&::-webkit-inner-spin-button // @stylint ignore
				margin 0
				appearance none




	&_width
		&_full
			width 100%
			max-width 100%

	&__textarea
		resize none
		height 108px
		min-height 48px
		max-height 188px
		padding-top 13px
		padding-bottom 13px
		line-height 20px

		&::-webkit-scrollbar-track
			background-color transparent

		&::-webkit-scrollbar
			width 8px
			height 8px
			background-color transparent
			background-clip padding-box
			border 2px solid transparent
			border-radius 4px

		&::-webkit-scrollbar-thumb
			background-clip padding-box
			border 2px solid transparent
			border-radius 4px



	&__check-group
		display block
		padding 7px 0 0

		+above(size-l)
			padding 3px 0 0



	// Modifiers


	&__input
		&_size
			&_s
				height 33px
				padding 8px 11px
				font-size 12px
				line-height 14px
				placeholder(var(--color-gray), 12px)

		&_style
			&_transparent
				color var(--color-white)
				background transparent
				border 1px solid rgba(204, 204, 204, 1) // Можно так?


				&.form-control__input_state
					&_invalid
						color var(--color-red)
						border 1px solid var(--color-red)
						placeholder(var(--color-red), 16px)