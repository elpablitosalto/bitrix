mixin form-control(data)
	- var DIR = 'assets/blocks/form-control/';
	- var IMG_DIR = DIR + 'images/';
	// begin .form-control
	+b.form-control&attributes(attributes)
		if data
			- var holderTag = data.type === 'checkbox' || data.type === 'radio' ? '' : data.holderTag || 'label';
			+e(holderTag).holder
				if data.label
					+e.label
						!=data.label

				- var attr = data.attr || {};
				if data.type === 'checkbox' || data.type === 'radio'
					- var wrapperClass = data.wrapperClass || '';
					+e.check-group(class=wrapperClass)
						if data.items
							each item in data.items
								+e.check-item
									- item.attr = item.attr || {};
									- item.attr.type = item.attr.type || data.type;
									- var itemClass = item.class || '';
									+check-elem(item)(class=itemClass)
										!=item.label

				else if data.type === 'switch'
					+e.switch-group
						if data.items
							each item in data.items
								+e.switch-item
									- var itemClass = item.class || '';

									+switch(item)(class=itemClass)

				else if data.type === 'radio-panels'
					+e.radio-panels
						+radio-panels({items: data.items})&attributes(attr)

				else if data.type === 'quantity'
					+e.quantity-input
						+quantity-input(data.content)&attributes(attr)

				else if data.type === 'file-panel'
					+e.field
						- var wrapperClass = data.wrapperClass || '';
						+e.file(class=wrapperClass)
							+file-input(data.content)

				else if data.type === 'select'
					+e.field
						+e('select').select&attributes(attr)
							if data.items
								if data.placeholder
									+e('option').option(value='' selected disabled hidden)
										!=data.placeholder

								each item in data.items
									+e('option').option(value=item.value)
										!=item.text

				else if data.type === 'choices-select'
						+e.field
							- data.label = '';
							+choices-select(data).__choices-select

				else if data.type === 'textarea'
					+e.field
						if data.iconPrev
							+e.decoration
								+icon(data.iconPrev).icon

						- var value = attr.value || '';
						- attr.value = false;

						// Modifiers
						// form-control__textarea_state_invalid - red border, one of the two options to show invalid field
						+e('textarea').textarea&attributes(attr)
							!=value

				else
					- var type = data.type || 'text';
					+e.field
						if data.iconPrev
							+e.decoration
								+icon(data.iconPrev).icon

						// Modifiers
						// form-control__input_state_invalid - red border, one of the two options to show invalid field
						+e('input').input(type=type)&attributes(attr)


						// Иконка показывается, когда поле прошло валидацию и инпут имеет класс form-control__input_state_success
						+e('svg').icon_success(width="13" height="9" viewBox="0 0 13 9" fill="none" xmlns="http://www.w3.org/2000/svg")
							path(d="M1.91284 3.30769L5.72237 7L11.9128 1" stroke="black" stroke-width="2" stroke-linecap="round")


						// Иконка показывается, когда поле не прошло валидацию и инпут имеет класс form-control__input_state_error
						+e('svg').icon_error(width="9" height="8" viewBox="0 0 9 8" fill="none" xmlns="http://www.w3.org/2000/svg")
							path(d="M1.91284 1L7.91284 7" stroke="#FF0000" stroke-width="2" stroke-linecap="round")
							path(d="M7.91284 1L1.91284 7" stroke="#FF0000" stroke-width="2" stroke-linecap="round")


						if data.showPasswordTrigger
							+e('button').trigger._type_password._password-state_hidden.js-show-password(type='button')
								<svg class="form-control__icon-password form-control__icon-password_state_hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
