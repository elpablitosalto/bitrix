								</svg>
								<svg  class="form-control__icon-password form-control__icon-password_state_visible" width="22" height="16" viewBox="0 0 22 16" fill="none" xmlns="http://www.w3.org/2000/svg">
									<path d="M11 12.5859C12.25 12.5859 13.3125 12.1484 14.1875 11.2734C15.0625 10.3984 15.5 9.33594 15.5 8.08594C15.5 6.83594 15.0625 5.77344 14.1875 4.89844C13.3125 4.02344 12.25 3.58594 11 3.58594C9.75 3.58594 8.6875 4.02344 7.8125 4.89844C6.9375 5.77344 6.5 6.83594 6.5 8.08594C6.5 9.33594 6.9375 10.3984 7.8125 11.2734C8.6875 12.1484 9.75 12.5859 11 12.5859ZM11 10.7859C10.25 10.7859 9.6125 10.5234 9.0875 9.99844C8.5625 9.47344 8.3 8.83594 8.3 8.08594C8.3 7.33594 8.5625 6.69844 9.0875 6.17344C9.6125 5.64844 10.25 5.38594 11 5.38594C11.75 5.38594 12.3875 5.64844 12.9125 6.17344C13.4375 6.69844 13.7 7.33594 13.7 8.08594C13.7 8.83594 13.4375 9.47344 12.9125 9.99844C12.3875 10.5234 11.75 10.7859 11 10.7859ZM11 15.5859C8.56667 15.5859 6.35 14.9068 4.35 13.5484C2.35 12.1901 0.9 10.3693 0 8.08594C0.9 5.8026 2.35 3.98177 4.35 2.62344C6.35 1.2651 8.56667 0.585938 11 0.585938C13.4333 0.585938 15.65 1.2651 17.65 2.62344C19.65 3.98177 21.1 5.8026 22 8.08594C21.1 10.3693 19.65 12.1901 17.65 13.5484C15.65 14.9068 13.4333 15.5859 11 15.5859ZM11 13.5859C12.8833 13.5859 14.6125 13.0901 16.1875 12.0984C17.7625 11.1068 18.9667 9.76927 19.8 8.08594C18.9667 6.4026 17.7625 5.0651 16.1875 4.07344C14.6125 3.08177 12.8833 2.58594 11 2.58594C9.11667 2.58594 7.3875 3.08177 5.8125 4.07344C4.2375 5.0651 3.03333 6.4026 2.2 8.08594C3.03333 9.76927 4.2375 11.1068 5.8125 12.0984C7.3875 13.0901 9.11667 13.5859 11 13.5859Z" fill="currentColor"/>
								</svg>



						if data.searchResult
							// form-control__result - is hidden
							// form-control__result_state_shown to show
							// form-control__result_state_hidden to hide, priority over _state_show
							+e.result._state_shown
								// search-results - no matches message shown
								// search-results_state_filled - search results shown
								// search-results_state_no-results - no matches message shown, priority over _state_filled
								+search-results(data.searchResult)._state_filled

				if data.link
					+e.links
						- var linkAttr = data.link.attr || {};
						+link()&attributes(linkAttr)
							!=data.link.text

				+e.messages
					if data.code
						+e.message
							| Запросить код повторно можно через 30 сек.
					else
						+e.message._style_error(style="display: none;")
							if data.message
								!=data.message
							else
								| Ошибка поля

				block
	// end .form-control
