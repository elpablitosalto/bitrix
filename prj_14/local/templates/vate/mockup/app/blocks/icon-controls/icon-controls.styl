DIR = '../blocks/icon-controls/'
IMG_DIR = DIR + 'images/'

.icon-controls
	display block



	&__list
		display flex
		flex-wrap nowrap
		align-items flex-start
		margin 0
		padding 0



	&__item
		display block
		flex 0 1 auto
		width auto
		margin 0 20px 0 0

		+above(size-m)
			margin 0 15px 0 0

		+above(size-xxl)
			margin 0 12.5px 0 0

		&:last-child
			margin-right 0

		&_hide
			&-m
				+above(size-m)
					display none

			&-xxl
				+above(size-xxl)
					display none

		&_show
			&-m
				display none

				+above(size-m)
					display block

	&_style
		&_primary
			.icon-controls
				&__list
					justify-content space-between